{
  "manifest_version": 3,
  "name": "Note Sidebar",
  "version": "1.2.0",
  "description": "Open NotebookLM in a Chrome side panel on any page, and add the current page as a source with one click.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Note Sidebar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject_button.js"],
      "run_at": "document_idle",
      "exclude_matches": ["https://gemini.google.com/*", "https://notebooklm.google.com/*"]
    }
  ],
  "permissions": [
    "declarativeNetRequest",
    "tabs",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
